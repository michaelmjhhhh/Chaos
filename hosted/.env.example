# Copy these into the Vercel project's Environment Variables (not committed).

# Shared token the Chaos app sends as the first half of its Bearer.
# Must match HostedProvider.bundledCredential baked into the app. Use a long random string.
APP_TOKEN=replace-with-a-long-random-string

# Separate admin token that gates POST /api/usage (reset a device's trial counter).
# Used only for testing/ops; keep it secret and different from APP_TOKEN.
ADMIN_TOKEN=replace-with-another-long-random-string

# Your Agnes AI key — kept server-side only, never shipped in the app.
AGNES_API_KEY=replace-with-your-agnes-key
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
MODEL=agnes-2.0-flash

# Free names per device, and the hard monthly spend ceiling (in successful calls).
# The bundled app token is public, so device hashes are attacker-pickable: GLOBAL_MONTHLY_LIMIT
# is your real blast-radius cap. Keep it as low as your trial budget allows and pair it with a
# hard spend cap on the upstream provider account. Each call is also clamped server-side
# (single completion, max_tokens <= 512) so one request can't be inflated.
FREE_LIMIT=20
GLOBAL_MONTHLY_LIMIT=5000

# Upstash Redis — added automatically when you attach the Upstash integration on Vercel:
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
